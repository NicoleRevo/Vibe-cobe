  <script>
    function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#039;');}
    function formatDate(iso){return new Date(iso+'T12:00:00').toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit',year:'numeric'});}
    function formatSize(kb){return kb>=1024?(kb/1024).toFixed(1)+' MB':kb+' KB';}
    function folderSize(folder){var total=folder.docs.reduce(function(s,d){return s+d.size;},0);folder.subFolders.forEach(function(sf){total+=folderSize(sf);});return total;}

    const typeIconSvg={
      PDF:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M9 15h6m-6-3h2"/></svg>',
      DOCX:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>',
      XLSX:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="17"/><line x1="16" y1="13" x2="8" y2="17"/></svg>'
    };
    const typeIconSvgDefault='<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>';
    const typeIconSvgLg={
      PDF:'<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M9 15h6m-6-3h2"/></svg>',
      DOCX:'<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>',
      XLSX:'<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="17"/><line x1="16" y1="13" x2="8" y2="17"/></svg>'
    };
    const typeIconSvgLgDefault='<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>';

    function showToast(msg, type){
      const t=type||'success';
      const icons={
        success:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
        error:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>',
        info:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>'
      };
      const el=document.createElement('div');
      el.className='toast '+t;
      el.innerHTML=icons[t]+'<span class="toast-msg">'+esc(msg)+'</span>';
      document.getElementById('toastContainer').appendChild(el);
      setTimeout(function(){el.remove();},3500);
    }

    function openModal(id){const el=document.getElementById(id);el.style.display='flex';requestAnimationFrame(function(){el.classList.add('show');});}
    function closeModal(id){const el=document.getElementById(id);el.classList.remove('show');setTimeout(function(){el.style.display='none';},200);}
    document.querySelectorAll('[data-close]').forEach(function(btn){btn.addEventListener('click',function(){closeModal(btn.dataset.close);});});
    document.querySelectorAll('.modal-overlay').forEach(function(o){o.addEventListener('click',function(e){if(e.target===o)closeModal(o.id);});});

    const state={scenario:'empty',view:'list',search:'',type:'all',order:'recent',selected:new Set(),docs:[],folders:[],folderStack:[],quickFilter:null};

    const mockDocs=[
      {id:1,name:'Entidades.xlsx',type:'XLSX',date:'2026-06-02',uploadDate:'2026-06-02',owner:'Ana Rocha',size:7,xlsxBase64:'',version:'3.2'},
      {id:2,name:'Projetos.pdf',type:'PDF',date:'2026-06-02',uploadDate:'2026-06-02',owner:'Ana Rocha',size:189,pdfPath:'Projetos.pdf',version:'1.0'}
    ];

    function getAllDocs(folders){
      var all=[];
      folders.forEach(function(f){all=all.concat(f.docs);all=all.concat(getAllDocs(f.subFolders));});
      return all;
    }

    function getFiltered(){
      if(state.quickFilter==='favoritos'){
        var all=state.docs.slice().concat(getAllDocs(state.folders));
        return all.filter(function(d){return d.favorited;});
      }
      if(state.quickFilter==='recentes'){
        var all=state.docs.slice().concat(getAllDocs(state.folders));
        all.sort(function(a,b){return b.date.localeCompare(a.date);});
        return all.slice(0,10);
      }
      const cur=state.folderStack.length?state.folderStack[state.folderStack.length-1]:null;
      let items=(cur?cur.docs:state.docs).slice();
      if(state.search){const q=state.search.toLowerCase();items=items.filter(function(d){return d.name.toLowerCase().includes(q)||d.owner.toLowerCase().includes(q);}); }
      if(state.type!=='all')items=items.filter(function(d){return d.type===state.type;});
      if(state.order==='name')items.sort(function(a,b){return a.name.localeCompare(b.name,'pt-BR');});
      else if(state.order==='name_desc')items.sort(function(a,b){return b.name.localeCompare(a.name,'pt-BR');});
      else if(state.order==='size')items.sort(function(a,b){return b.size-a.size;});
      else if(state.order==='size_asc')items.sort(function(a,b){return a.size-b.size;});
      else if(state.order==='type')items.sort(function(a,b){var t=a.type.localeCompare(b.type,'pt-BR');return t!==0?t:a.name.localeCompare(b.name,'pt-BR');});
      else if(state.order==='oldest')items.sort(function(a,b){return a.date.localeCompare(b.date);});
      else items.sort(function(a,b){return b.date.localeCompare(a.date);});
      return items;
    }

    function getAllFolders(folders){
      var all=[];
      folders.forEach(function(f){all.push(f);all=all.concat(getAllFolders(f.subFolders));});
      return all;
    }

    function getFilteredFolders(){
      if(state.quickFilter==='favoritos'){
        return getAllFolders(state.folders).filter(function(f){return f.favorited;});
      }
      if(state.quickFilter==='recentes') return [];
      const cur=state.folderStack.length?state.folderStack[state.folderStack.length-1]:null;
      const src=cur?cur.subFolders:state.folders;
      if(!state.search) return src.slice();
      const q=state.search.toLowerCase();
      return src.filter(function(f){return f.name.toLowerCase().includes(q);});
    }

    function render(){
      const docs=getFiltered();const folders=getFilteredFolders();const has=docs.length>0||folders.length>0;
      const totalKB=docs.reduce(function(s,d){return s+d.size;},0);

      const badge=document.getElementById('countBadge');badge.style.display='none';
      const bc=document.getElementById('breadcrumb');
      if(state.folderStack.length){
        bc.style.display='flex';
        const container=document.getElementById('breadcrumbItems');
        container.innerHTML='';
        function addSep(){const s=document.createElement('span');s.className='breadcrumb-sep';s.textContent='>';container.appendChild(s);}
        state.folderStack.forEach(function(f,i){
          addSep();
          if(i===state.folderStack.length-1){
            const cur=document.createElement('span');cur.className='breadcrumb-current';cur.textContent=f.name;container.appendChild(cur);
          } else {
            const link=document.createElement('span');link.className='breadcrumb-link';link.textContent=f.name;
            link.addEventListener('click',(function(idx){return function(){state.folderStack=state.folderStack.slice(0,idx+1);render();};})(i));
            container.appendChild(link);
          }
        });
      } else { bc.style.display='none'; }
      var isFavEmpty=state.quickFilter==='favoritos'&&!has;
      var isRecEmpty=state.quickFilter==='recentes'&&!has;
      var isQuickEmpty=isFavEmpty||isRecEmpty;
      document.getElementById('emptyStateFavoritos').style.display=isFavEmpty?'flex':'none';
      document.getElementById('emptyStateRecentes').style.display=isRecEmpty?'flex':'none';
      document.getElementById('emptyState').style.display=(!isQuickEmpty&&!has)?'flex':'none';
      document.getElementById('tableWrap').classList.toggle('show',has&&state.view==='list');
      document.getElementById('gridWrap').classList.toggle('show',has&&state.view==='grid');
      if(has){if(state.view==='list')renderTable(folders,docs);else renderGrid(folders,docs);}
      const ca=document.getElementById('checkAll');if(ca){ca.checked=false;ca.disabled=true;}
      updateSelectionBar();
      var favBack=document.getElementById('emptyFavBack');
      if(favBack)favBack.onclick=function(){state.quickFilter=null;state.folderStack=[];render();};
      var recBack=document.getElementById('emptyRecBack');
      if(recBack)recBack.onclick=function(){state.quickFilter=null;state.folderStack=[];render();};
      refreshTree();
    }

    function refreshTree(){
      var container=document.getElementById('folderTree');
      var panel=document.getElementById('folderTreePanel');
      if(!container)return;
      container.innerHTML='';
      var hasFolders=state.folders.length>0;
      if(panel)panel.style.display=hasFolders?'flex':'none';
      if(!hasFolders)return;

      // -- Root "Documentos" item with collapsible children --
      var rootExpanded=state._rootExpanded!==false;
      var rootLi=document.createElement('li');rootLi.className='tree-li';
      var rootRow=document.createElement('div');
      var isRoot=state.folderStack.length===0&&!state.quickFilter;
      rootRow.className='tree-row'+(isRoot?' selected':'');
      var rootToggle=document.createElement('span');
      rootToggle.className='tree-toggle'+(rootExpanded?' open':'');
      rootToggle.innerHTML='<svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="9 18 15 12 9 6"/></svg>';
      rootToggle.addEventListener('click',function(e){
        e.stopPropagation();
        state._rootExpanded=!rootExpanded;
        refreshTree();
      });
      rootRow.appendChild(rootToggle);
      var rootIcon=document.createElement('span');rootIcon.className='tree-folder-icon';
      rootIcon.innerHTML='<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/><line x1="2" y1="10" x2="22" y2="10"/></svg>';
      rootRow.appendChild(rootIcon);
      var rootLabel=document.createElement('span');rootLabel.className='tree-label';rootLabel.style.fontWeight='600';rootLabel.textContent='Documentos';rootRow.appendChild(rootLabel);
      rootRow.addEventListener('click',function(){
        state.folderStack=[];state.quickFilter=null;state.search='';
        document.getElementById('searchInput').value='';render();
      });
      rootLi.appendChild(rootRow);
      if(rootExpanded){
        var rootChildUl=document.createElement('ul');rootChildUl.className='tree-ul tree-children';
        state.folders.forEach(function(folder){buildNode(folder,[],rootChildUl);});
        rootLi.appendChild(rootChildUl);
      }
      container.appendChild(rootLi);

      // -- Quick access: Favoritos and Recentes (below Documentos, same list) --
      var quickItems=[
        {label:'Favoritos',filter:'favoritos',icon:'<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>'},
        {label:'Recentes',filter:'recentes',icon:'<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>'}
      ];
      quickItems.forEach(function(item){
        var isActive=state.quickFilter===item.filter;
        var li=document.createElement('li');li.className='tree-li';
        var row=document.createElement('div');row.className='tree-row quick'+(isActive?' selected':'');
        var ph=document.createElement('span');ph.className='tree-toggle-ph';row.appendChild(ph);
        var icon=document.createElement('span');icon.className='tree-folder-icon';icon.innerHTML=item.icon;row.appendChild(icon);
        var label=document.createElement('span');label.className='tree-label';label.textContent=item.label;row.appendChild(label);
        row.addEventListener('click',(function(f){return function(){
          state.quickFilter=state.quickFilter===f?null:f;
