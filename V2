<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Biblioteca de Documentos | Target</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../ux-prototypes/design-tokens/colors.css">
  <link rel="stylesheet" href="../ux-prototypes/design-tokens/typography.css">
  <link rel="stylesheet" href="../ux-prototypes/design-tokens/spacing.css">
  <script src="https://cdn.sheetjs.com/xlsx-0.20.3/package/dist/xlsx.full.min.js"></script>
  <style>
    /* -- RESET -- */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue: #1a56a0;
      --blue-dark: #153f7c;
      --blue-light: #e8f0fb;
      --blue-border: #c5d8f5;
      --text: #2c3e50;
      --text-muted: #6b7a8d;
      --text-light: #9aabb8;
      --border: #dde3ea;
      --border-focus: #1a56a0;
      --bg: #f5f7fa;
      --white: #ffffff;
      --success: #1e8c4e;
      --success-bg: #e6f6ed;
      --error: #c0392b;
      --error-bg: #fdecea;
      --warning: #b45309;
      --warning-bg: #fef3c7;
      --radius: 4px;
      --radius-md: 6px;
      --shadow: 0 2px 12px rgba(0,0,0,.12);
      --shadow-sm: 0 1px 4px rgba(0,0,0,.08);
      --sidebar-bg: #1a2844;
      --sidebar-width: 230px;
      --header-height: 50px;
    }

    body {
      font-family: 'Roboto', sans-serif;
      color: var(--text);
      background: var(--bg);
      font-size: 14px;
      line-height: 1.5;
      min-height: 100vh;
      overflow: hidden;
    }

    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #c4cdd6; border-radius: 4px; }

    /* -- TARGET HEADER -- */
    .target-header {
      background: #f3f3f3;
      height: var(--header-height);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 15px;
      border-bottom: 1px solid #e0e0e0;
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 200;
    }
    .header-left, .header-right { display: flex; align-items: center; gap: 18px; }
    .logo { height: 30px; }
    .year-badge { background: #003366; color: #fff; padding: 2px 10px; border-radius: 12px; font-weight: 700; font-size: 12px; }
    .header-icons { display: flex; align-items: center; gap: 18px; }
    .header-icons svg, .header-right svg { cursor: pointer; width: 18px; height: 18px; color: #555; transition: color .15s; flex-shrink: 0; }
    .header-icons svg:hover, .header-right svg:hover { color: #1a56a0; }
    .notification-wrapper { position: relative; display: flex; align-items: center; }
    .notification-wrapper .dot { position: absolute; top: -2px; right: -2px; width: 6px; height: 6px; background: #e53935; border-radius: 50%; border: 1px solid #f3f3f3; }
    .ia-icon-wrapper { background: #fff; padding: 6px; border-radius: 10px; cursor: pointer; box-shadow: 0 1px 3px rgba(0,0,0,.1); border: 1px solid #ddd; display: flex; align-items: center; }
    .ia-icon-wrapper svg { width: 16px; height: 16px; color: #555; }
    .user-avatar img { width: 32px; height: 32px; border-radius: 50%; object-fit: cover; }

    /* -- APP SHELL -- */
    .app-shell {
      display: flex;
      height: calc(100vh - var(--header-height));
      margin-top: var(--header-height);
      overflow: hidden;
    }

    /* -- MAIN CONTENT -- */
    .main-content {
      flex: 1;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      background: var(--bg);
    }
    .main-content::-webkit-scrollbar { width: 6px; }
    .main-content::-webkit-scrollbar-thumb { background: #c4cdd6; border-radius: 4px; }

    /* -- SCENARIO BAR -- */
    .scenario-bar {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 6px 20px;
      background: var(--warning-bg);
      border-bottom: 1px solid #fde68a;
      font-size: 12px;
      font-weight: 600;
      color: #92400e;
      flex-shrink: 0;
    }
    .scenario-bar svg { color: #b45309; width: 16px; height: 16px; flex-shrink: 0; }
    .scenario-btn {
      height: 22px;
      padding: 0 10px;
      border: 1px solid #fcd34d;
      border-radius: var(--radius);
      background: var(--white);
      color: #92400e;
      font-family: inherit;
      font-size: 11px;
      font-weight: 600;
      cursor: pointer;
      transition: background .15s;
    }
    .scenario-btn.active { background: #f59e0b; color: #fff; border-color: #d97706; }
    .scenario-btn:hover:not(.active) { background: #fef3c7; }

    /* -- PAGE HEADER -- */
    .page-header {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 20px 20px 12px;
      flex-shrink: 0;
    }
    .page-header-icon {
      width: 40px; height: 40px;
      background: var(--blue-light);
      border-radius: var(--radius-md);
      display: flex; align-items: center; justify-content: center;
      color: var(--blue);
      font-size: 20px;
      flex-shrink: 0;
    }
    .page-header-title { font-size: 17px; font-weight: 700; color: var(--text); }
    .page-header-sub {
      font-size: 12px;
      color: var(--text-muted);
      display: flex; gap: 4px; align-items: center;
      margin-top: 2px;
    }
    .page-header-sub a { color: var(--blue); text-decoration: none; }
    .page-header-sub a:hover { text-decoration: underline; }
    .page-header-sub span { color: var(--border); }

    /* -- PORTLET -- */
    .portlet {
      background: var(--white);
      border-radius: 10px;
      box-shadow: 0 1px 6px rgba(0,0,0,.07);
      margin: 0 20px 20px;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      flex: 1;
      min-height: 0;
    }
    .portlet-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 18px;
      border-bottom: 1px solid #e8eaed;
      flex-shrink: 0;
    }
    .portlet-title {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 15px;
      font-weight: 700;
      color: var(--text);
    }
    .portlet-title svg { color: var(--blue); width: 17px; height: 17px; flex-shrink: 0; }
    .back-btn {
      display: flex; align-items: center; justify-content: center;
      width: 26px; height: 26px; border-radius: 6px; border: 1px solid var(--border);
      background: transparent; cursor: pointer; color: var(--text-muted); padding: 0; flex-shrink: 0;
      transition: background .15s, color .15s;
    }
    .back-btn:hover { background: var(--blue-light); color: var(--blue); border-color: var(--blue); }
    .count-badge {
      background: var(--blue-light);
      color: var(--blue);
      border-radius: 10px;
      padding: 2px 8px;
      font-size: 11px;
      font-weight: 700;
    }
    .portlet-actions { display: flex; align-items: center; gap: 4px; }
    .portlet-btn {
      background: none; border: none; cursor: pointer;
      padding: 4px 6px; border-radius: var(--radius);
      color: var(--text-muted); font-size: 16px;
      display: flex; align-items: center; justify-content: center;
      transition: background .15s, color .15s;
    }
    .portlet-btn:hover { background: var(--bg); color: var(--text); }

    /* -- PORTLET BODY -- */
    .portlet-body {
      position: relative;
      overflow: hidden;
      flex: 1;
      min-height: 0;
      display: flex;
      flex-direction: row;
    }
    .portlet-main {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      position: relative;
    }

    /* -- DRAG OVERLAY -- */
    .drag-overlay {
      position: absolute;
      inset: 0;
      background: rgba(26,86,160,.07);
      border: 3px dashed var(--blue);
      z-index: 40;
      display: none;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 12px;
      pointer-events: none;
      border-radius: 0;
    }
    .drag-overlay.active { display: flex; }
    .drag-overlay-label { font-size: 18px; font-weight: 700; color: var(--blue); }
    .drag-overlay-sub { font-size: 13px; color: var(--text-muted); }

    /* -- TOOLBAR -- */
    .toolbar {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 18px;
      border-bottom: 1px solid var(--border);
      background: #fafbfc;
      flex-wrap: wrap;
      flex-shrink: 0;
    }
    .toolbar-search-wrap {
      flex: 1;
      min-width: 180px;
      position: relative;
    }
    .toolbar-search-wrap svg {
      position: absolute;
      left: 9px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-light);
      width: 15px; height: 15px;
      pointer-events: none;
    }
    .toolbar-input {
      width: 100%;
      height: 32px;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 0 10px 0 30px;
      font-family: inherit;
      font-size: 13px;
      color: var(--text);
      background: var(--white);
      transition: border-color .15s;
    }
    .toolbar-input:focus { outline: none; border-color: var(--border-focus); box-shadow: 0 0 0 3px rgba(26,86,160,.1); }
    .toolbar-select {
      height: 32px;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 0 28px 0 10px;
      font-family: inherit;
      font-size: 13px;
      color: var(--text);
      background: var(--white) url("data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='10' height='10' viewBox='0 0 24 24'%3E%3Cpath fill='%236b7a8d' d='M7 10l5 5 5-5z'/%3E%3C/svg%3E") no-repeat right 8px center;
      appearance: none;
      cursor: pointer;
      transition: border-color .15s;
    }
    .toolbar-select:focus { outline: none; border-color: var(--border-focus); }
    .toolbar-divider { width: 1px; height: 22px; background: var(--border); flex-shrink: 0; }
    .view-toggle { display: flex; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
    .view-toggle-btn {
      width: 32px; height: 32px;
      border: none; background: var(--white);
      color: var(--text-light);
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      font-size: 16px;
      border-right: 1px solid var(--border);
      transition: background .15s, color .15s;
    }
    .view-toggle-btn:last-child { border-right: none; }
    .view-toggle-btn.active { background: var(--blue-light); color: var(--blue); }
    .view-toggle-btn:hover:not(.active) { background: var(--bg); color: var(--text-muted); }

    /* -- BUTTONS -- */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: var(--space-1, 4px);
      height: 40px;
      padding: 0 var(--space-6, 24px);
      border-radius: var(--radius-md, 8px);
      font-family: inherit;
      font-size: var(--font-size-sm, 14px);
      font-weight: var(--font-weight-medium, 500);
      cursor: pointer;
      transition: background .15s, border-color .15s, color .15s, box-shadow .15s;
      white-space: nowrap;
      border: 1px solid transparent;
    }
    .btn:focus-visible {
      outline: none;
      box-shadow: var(--shadow-focus, 0 0 0 3px rgba(108,71,255,.25));
    }
    .btn svg { width: 16px; height: 16px; flex-shrink: 0; }
    .btn-primary { background: #003366; color: #fff; border-color: #003366; }
    .btn-primary:hover { background: #1a56a0; border-color: #1a56a0; }
    .btn-primary:active { background: #002244; border-color: #002244; }
    .btn-secondary { background: var(--color-neutral-0, #fff); color: #003366; border-color: #003366; }
    .btn-secondary:hover { background: #e8f0fb; }
    .btn-ghost { background: transparent; color: var(--color-neutral-600, #4A4A6A); border-color: var(--color-border-default, #E2E2EF); }
    .btn-ghost:hover { background: var(--color-neutral-100, #F0F0F8); color: var(--color-neutral-700, #2E2E50); }
    .btn-danger { background: var(--color-neutral-0, #fff); color: var(--color-error, #EF4444); border-color: var(--color-error-light, #FEE2E2); }
    .btn-danger:hover { background: var(--color-error-light, #FEE2E2); }
    .btn-sm { height: 32px; font-size: var(--font-size-xs, 12px); padding: 0 var(--space-2, 8px); gap: var(--space-1, 4px); }
    .btn-icon { width: 40px; padding: 0; justify-content: center; }

    /* -- SELECTION BAR -- */
    .selection-bar {
      display: none;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      padding: 7px 18px;
      background: var(--blue-light);
      border-bottom: 1px solid var(--blue-border);
      flex-shrink: 0;
      flex-wrap: wrap;
    }
    .selection-bar.show { display: flex; }
    .selection-info { display: flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 600; color: var(--blue); }
    .selection-info svg { width: 15px; height: 15px; }
    .selection-actions { display: flex; gap: 6px; flex-wrap: wrap; }

    /* -- DROPZONE -- */
    .dropzone {
      margin: 10px 18px;
      border: 2px dashed var(--border);
      border-radius: var(--radius-md);
      padding: 10px 18px;
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      color: var(--text-muted);
      cursor: pointer;
      transition: border-color .15s, background .15s, color .15s;
      background: #fafbfc;
      flex-shrink: 0;
    }
    .dropzone:hover, .dropzone.drag-over { border-color: var(--blue); background: var(--blue-light); color: var(--blue); }
    .dropzone svg { width: 20px; height: 20px; flex-shrink: 0; }
    .dropzone strong { font-weight: 600; color: var(--text); }

    /* -- META ROW -- */
    .meta-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 5px 18px;
      font-size: 12px;
      color: var(--text-muted);
      flex-shrink: 0;
    }

    /* -- BREADCRUMB BAR -- */
    .breadcrumb-bar {
      display: flex;
      align-items: center;
      gap: 0;
      padding: 7px 18px;
      border-bottom: 1px solid var(--border);
      background: var(--white);
      flex-shrink: 0;
      font-size: 13px;
    }
    .breadcrumb-home {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      color: var(--blue);
      cursor: pointer;
      font-weight: 500;
      padding: 2px 4px;
      border-radius: 4px;
    }
    .breadcrumb-home:hover { text-decoration: underline; background: var(--surface); }
    .breadcrumb-link { color: var(--blue); cursor: pointer; font-weight: 500; padding: 2px 4px; border-radius: 4px; }
    .breadcrumb-link:hover { text-decoration: underline; background: var(--surface); }
    .breadcrumb-sep { color: var(--text-light); margin: 0 2px; }
    .breadcrumb-current { font-weight: 600; color: var(--text); padding: 2px 4px; }

    /* -- EMPTY STATE -- */
    .empty-state {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 60px 32px;
      gap: 10px;
    }
    .empty-icon { width: 68px; height: 68px; background: var(--blue-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--blue); font-size: 30px; margin-bottom: 6px; }
    .empty-title { font-size: 17px; font-weight: 700; color: var(--text); margin: 0; }
    .empty-desc { font-size: 13px; color: var(--text-muted); max-width: 22rem; margin: 0; }
    .empty-actions { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; margin-top: 8px; }
    .empty-hint { font-size: 11px; color: var(--text-light); margin-top: 4px; max-width: 22rem; }

    /* -- TABLE -- */
    .table-wrap { flex: 1; overflow-y: auto; display: none; }
    .table-wrap.show { display: block; }
    .data-table { width: 100%; border-collapse: collapse; }
    .data-table thead th {
      background: #eef2f8;
      border-bottom: 2px solid #d4dde9;
      padding: 8px 14px;
      text-align: left;
      font-size: 11.5px;
      font-weight: 700;
      color: var(--text-muted);
      white-space: nowrap;
      text-transform: uppercase;
      position: sticky;
      top: 0;
      z-index: 1;
    }
    .data-table thead th.col-check, .data-table tbody td.col-check { width: 40px; text-align: center; }
    .data-table thead th.col-actions, .data-table tbody td.col-actions { text-align: right; width: 110px; }
    .data-table tbody tr { border-bottom: 1px solid var(--border); transition: background .12s; }
    .data-table tbody tr:hover { background: #fafbfc; }
    .data-table tbody tr.selected { background: var(--blue-light); }
    .data-table tbody td { padding: 9px 14px; font-size: 13px; vertical-align: middle; }
    .data-table .col-actions div { display: flex; gap: 2px; justify-content: flex-end; }
    .data-table tfoot td { padding: 8px 14px; font-size: 12px; color: var(--text-muted); border-top: 2px solid #d4dde9; background: #f7f9fc; }
    .foot-count strong { color: var(--blue); }
    .file-name { font-weight: 600; color: var(--text); display: flex; align-items: center; gap: 6px; }
    .file-name svg { color: var(--blue); width: 16px; height: 16px; flex-shrink: 0; }
    .col-kebab { width: 36px; text-align: right; padding-right: 10px !important; }
    .kebab-btn { background: none; border: none; cursor: pointer; padding: 4px 6px; border-radius: 4px; color: var(--text-light); display: flex; align-items: center; }
    .kebab-btn:hover { background: var(--surface); color: var(--text); }
    .row-menu { position: fixed; z-index: 9999; background: #fff; border: 1px solid var(--border); border-radius: 8px; box-shadow: 0 4px 16px rgba(0,0,0,.12); min-width: 160px; padding: 6px 0; }
    .row-menu-item { display: flex; align-items: center; gap: 10px; padding: 8px 16px; font-size: 13px; cursor: pointer; color: var(--text); white-space: nowrap; }
    .row-menu-item:hover { background: var(--surface); }
    .row-menu-item.danger { color: #c0392b; }
    .row-menu-item.danger:hover { background: #fdf0ef; }

    /* -- TAGS -- */
    .tag {
      display: inline-flex; align-items: center;
      height: 18px; padding: 0 6px;
      border-radius: 9px;
      font-size: 10.5px; font-weight: 700;
    }
    .tag-pdf  { background: #fdecea; color: var(--error); }
    .tag-docx { background: #e8f0fb; color: var(--blue); }
    .tag-xlsx { background: var(--success-bg); color: var(--success); }

    /* -- FAVORITE BTN -- */
    .fav-btn {
      background: none; border: none; cursor: pointer;
      padding: 3px; border-radius: 4px;
      color: #c4cdd6;
      display: inline-flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      transition: color .15s, transform .15s;
      line-height: 1;
    }
    .fav-btn:hover { color: #f59e0b; transform: scale(1.15); }
    .fav-btn.active { color: #f59e0b; }
    .fav-btn.active svg { fill: #f59e0b; }
    /* star overlay on grid cards: always visible */
    .grid-card .fav-btn {
      background: rgba(255,255,255,.92);
      border: 1px solid #dde3ea;
      border-radius: 5px;
      color: #9aabb8;
      box-shadow: 0 1px 3px rgba(0,0,0,.10);
    }
    .grid-card .fav-btn:hover { background: #fff; color: #f59e0b; border-color: #f59e0b; }
    .grid-card .fav-btn.active { background: #fff; color: #f59e0b; border-color: #f59e0b; }

    /* -- GRID VIEW -- */
    .grid-wrap { flex: 1; overflow-y: auto; padding: 18px; display: none; grid-template-columns: repeat(auto-fill, minmax(12rem, 1fr)); gap: 14px; align-content: start; }
    .grid-wrap.show { display: grid; }
    .grid-card {
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: 14px;
      background: var(--white);
      box-shadow: var(--shadow-sm);
      display: flex; flex-direction: column; gap: 6px;
      transition: box-shadow .15s, border-color .15s;
      cursor: pointer;
      min-height: 148px;
      justify-content: space-between;
      position: relative;
    }
    .grid-card.has-preview { padding: 0; min-height: 200px; }
    .grid-card-preview {
      width: 100%;
      height: 100px;
      border-radius: var(--radius-md) var(--radius-md) 0 0;
      overflow: hidden;
      flex-shrink: 0;
      background: #f1f3f4;
      position: relative;
    }
    .grid-card-preview-pdf {
      background: #fff;
      display: flex; flex-direction: column;
      padding: 8px 10px;
      gap: 5px;
    }
    .grid-card-preview-pdf .pdf-header {
      height: 18px; background: #e53935; border-radius: 2px;
      display: flex; align-items: center; padding: 0 6px;
    }
    .grid-card-preview-pdf .pdf-header span {
      font-size: 8px; font-weight: 800; color: #fff; letter-spacing: .5px;
    }
    .grid-card-preview-pdf .pdf-line {
      height: 5px; background: #e8eaed; border-radius: 2px;
    }
    .grid-card-preview-pdf .pdf-line.short { width: 60%; }
    .grid-card-preview-pdf .pdf-line.mid   { width: 80%; }
    .grid-card-preview-pdf .pdf-line.full  { width: 100%; }
    .grid-card-preview-pdf .pdf-block {
      display: flex; gap: 5px; margin-top: 2px;
    }
    .grid-card-preview-pdf .pdf-block-col {
      flex: 1; display: flex; flex-direction: column; gap: 3px;
    }
    .grid-card-preview-xlsx {
      background: #fff;
      display: flex; flex-direction: column;
      overflow: hidden;
    }
    .grid-card-preview-xlsx .xlsx-tab {
      height: 14px; background: #1a7f4b;
      display: flex; align-items: center; padding: 0 7px;
    }
    .grid-card-preview-xlsx .xlsx-tab span {
      font-size: 7px; font-weight: 800; color: #fff; letter-spacing: .5px;
    }
    .grid-card-preview-xlsx .xlsx-grid {
      flex: 1; display: flex; flex-direction: column;
    }
    .grid-card-preview-xlsx .xlsx-row {
      display: flex; border-bottom: 1px solid #e8eaed;
    }
    .grid-card-preview-xlsx .xlsx-row.header .xlsx-cell {
      background: #e8f5e9; font-weight: 700; color: #1a7f4b; font-size: 6.5px;
    }
    .grid-card-preview-xlsx .xlsx-cell {
      flex: 1; border-right: 1px solid #e8eaed;
      padding: 2px 3px; font-size: 6px; color: #555;
      white-space: nowrap; overflow: hidden;
    }
    .grid-card-info {
      padding: 6px 10px 8px;
      display: flex; flex-direction: column; gap: 2px;
      flex: 1;
    }
    .grid-card-tag-area {
      position: absolute;
      top: 10px;
      right: 32px;
      display: flex;
      align-items: center;
    }
    .grid-card.has-preview .grid-card-tag-area { top: 8px; }
    .grid-card-menu-btn {
      position: absolute;
      top: 8px;
      right: 6px;
      padding: 2px;
      width: 22px;
      height: 22px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: none;
      background: transparent;
      border-radius: var(--radius-sm);
      color: var(--text-muted);
      cursor: pointer;
    }
    .grid-card-menu-btn:hover { background: var(--color-neutral-100, #F0F0F8); color: var(--text); }
    .grid-card:hover { box-shadow: var(--shadow); border-color: var(--blue-border); }
    .grid-card-top { display: flex; align-items: flex-start; justify-content: space-between; }
    .grid-card-icon { color: var(--blue); }
    .grid-card-name { font-size: 13px; font-weight: 600; color: var(--text); word-break: break-word; line-height: 1.35; margin: 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 2.7em; }
    .grid-card-meta { font-size: 11.5px; color: var(--text-muted); margin: 0; }
    .grid-card-footer { display: flex; gap: 6px; margin-top: 4px; }

    /* -- MODAL -- */
    .modal-overlay { position: fixed; inset: 0; background: rgba(30,40,55,.45); z-index: 400; display: none; align-items: center; justify-content: center; }
    .modal-overlay.show { display: flex; }
    .modal {
      background: var(--white);
      border-radius: 10px;
      box-shadow: var(--shadow);
      width: 440px;
      max-width: 95vw;
      max-height: 90vh;
      display: flex; flex-direction: column;
      animation: modalIn .2s ease;
    }
    @keyframes modalIn { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:translateY(0); } }
    .modal-header { display: flex; align-items: center; justify-content: space-between; padding: 16px 20px; border-bottom: 1px solid var(--border); flex-shrink: 0; }
    .modal-title { font-size: 16px; font-weight: 700; color: var(--text); margin: 0; }
    .modal-close { width: 32px; height: 32px; border: none; background: transparent; border-radius: var(--radius); display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--text-muted); font-size: 18px; transition: background .15s, color .15s; }
    .modal-close:hover { background: var(--bg); color: var(--text); }
    .modal-body { padding: 20px; display: flex; flex-direction: column; gap: 16px; overflow-y: auto; }
    .modal-footer { padding: 14px 20px; border-top: 1px solid var(--border); display: flex; justify-content: flex-end; gap: 10px; flex-shrink: 0; }
    .form-field { display: flex; flex-direction: column; gap: 5px; }
    .form-label { font-size: 13px; font-weight: 600; color: var(--text); }
    .form-label .req { color: var(--error); margin-left: 2px; }
    .form-input, .form-select {
      height: 34px;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 0 10px;
      font-family: inherit;
      font-size: 13px;
      color: var(--text);
      background: var(--white);
      transition: border-color .15s;
      width: 100%;
    }
    .form-input:focus, .form-select:focus { outline: none; border-color: var(--border-focus); box-shadow: 0 0 0 3px rgba(26,86,160,.1); }
    .form-hint { font-size: 11px; color: var(--text-muted); }

    /* -- TOASTS -- */
    .toast-container { position: fixed; top: 72px; right: 28px; z-index: 9999; display: flex; flex-direction: column; gap: 8px; }
    .toast {
      display: flex; align-items: center; gap: 10px;
      padding: 12px 22px;
      background: #1a7f4b;
      color: #fff;
      border-radius: 8px;
      box-shadow: 0 4px 16px rgba(0,0,0,.18);
      font-size: 14px; font-weight: 600;
      min-width: 220px; max-width: 360px;
      animation: toastIn .3s ease;
    }
    .toast.error { background: #c0392b; }
    .toast.info  { background: #1a56a0; }
    .toast svg { flex-shrink: 0; width: 18px; height: 18px; color: #fff; stroke: #fff; }
    .toast-msg { flex: 1; color: #fff; word-break: break-word; overflow-wrap: anywhere; }
    @keyframes toastIn { from { opacity:0; transform:translateY(-10px); } to { opacity:1; transform:translateY(0); } }

    /* -- PROTO BADGE -- */
    .proto-badge {
      position: fixed; top: 56px; right: 10px;
      background: var(--warning-bg); border: 1px solid #fcd34d;
      border-radius: var(--radius); padding: 2px 10px;
      font-size: 11px; font-weight: 700; color: #92400e;
      z-index: 150;
    }

    input[type="checkbox"] { accent-color: var(--blue); width: 15px; height: 15px; cursor: pointer; }

    @media (max-width: 768px) {
      .portlet { margin: 0 10px 10px; }
    }

    /* -- FOLDER TREE PANEL -- */
    .folder-tree-panel {
      width: 200px;
      min-width: 140px;
      background: var(--white);
      border-right: 1px solid var(--border);
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      user-select: none;
    }
    .tree-header {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 9px 12px 8px;
      font-size: 11px;
      font-weight: 700;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: .06em;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    .tree-header svg { color: var(--blue); }
    .tree-scroll {
      flex: 1;
      overflow-y: auto;
      padding: 4px 0;
    }
    .tree-scroll::-webkit-scrollbar { width: 4px; }
    .tree-scroll::-webkit-scrollbar-thumb { background: #c4cdd6; border-radius: 4px; }
    .tree-empty-hint {
      padding: 16px 14px;
      font-size: 12px;
      color: var(--text-light);
      line-height: 1.5;
    }
    .tree-ul { list-style: none; margin: 0; padding: 0; }
    .tree-li { position: relative; }
    .tree-row {
      display: flex;
      align-items: center;
      padding: 3px 8px 3px 0;
      cursor: pointer;
      border-radius: 3px;
      transition: background .1s;
      min-height: 26px;
      margin: 0 4px;
    }
    .tree-row:hover { background: #f0f4fa; }
    .tree-row.selected { background: #cfe2f7; }
    .tree-row.selected .tree-label { font-weight: 600; color: #1a3a6a; }
    .tree-toggle {
      width: 18px; height: 18px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      color: #9aabb8;
      border-radius: 3px;
      transition: background .1s, color .1s;
    }
    .tree-toggle:hover { background: #e0eaf5; color: #1a56a0; }
    .tree-toggle > svg { transition: transform .15s; }
    .tree-toggle.open > svg { transform: rotate(90deg); }
    .tree-toggle-ph { width: 18px; flex-shrink: 0; }
    .tree-folder-icon {
      flex-shrink: 0;
      color: #6b7a8d;
      margin: 0 3px;
      display: flex; align-items: center;
    }
    .tree-label {
      flex: 1;
      font-size: 12.5px;
      color: var(--text);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      line-height: 1.4;
    }
    .tree-children { padding-left: 14px; }
    .tree-section-title {
      padding: 10px 12px 4px;
      font-size: 10px;
      font-weight: 700;
      color: var(--text-light);
      text-transform: uppercase;
      letter-spacing: .07em;
    }
    .tree-divider { height: 1px; background: var(--border); margin: 6px 8px; }
    .tree-row.quick .tree-folder-icon { color: #6b7a8d; }

    /* -- SCROLLBAR: WINDOWS EXPLORER STYLE -- */
    .table-wrap::-webkit-scrollbar,
    .grid-wrap::-webkit-scrollbar  { width: 14px; height: 14px; }
    .table-wrap::-webkit-scrollbar-track,
    .grid-wrap::-webkit-scrollbar-track  { background: #f0f0f0; border-left: 1px solid #e0e0e0; }
    .table-wrap::-webkit-scrollbar-thumb,
    .grid-wrap::-webkit-scrollbar-thumb  { background: #c1c1c1; border: 3px solid #f0f0f0; border-radius: 0; }
    .table-wrap::-webkit-scrollbar-thumb:hover,
    .grid-wrap::-webkit-scrollbar-thumb:hover  { background: #a8a8a8; }
    .table-wrap::-webkit-scrollbar-thumb:active,
    .grid-wrap::-webkit-scrollbar-thumb:active { background: #787878; }
    .tree-scroll::-webkit-scrollbar { width: 4px; }
    .tree-scroll::-webkit-scrollbar-thumb { background: #c4cdd6; border-radius: 4px; }
    .folder-count-badge {
      display: inline-flex;
      align-items: center;
      height: 16px;
      padding: 0 6px;
      border-radius: 8px;
      font-size: 10.5px;
      font-weight: 700;
      margin-left: 6px;
      flex-shrink: 0;
      white-space: nowrap;
    }
    .folder-count-badge.empty { background: #f1f3f4; color: var(--text-light); }
    .folder-count-badge.has-files { background: var(--blue-light); color: var(--blue); }
  </style>
</head>
