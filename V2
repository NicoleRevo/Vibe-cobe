    // -- DRAG & DROP --
    (function(){
      var portletMain=document.querySelector('.portlet-main');
      var overlay=document.getElementById('dragOverlay');
      var dragCounter=0;
      function isFileDrag(e){return e.dataTransfer&&Array.from(e.dataTransfer.types).some(function(t){return t==='Files';});}
      portletMain.addEventListener('dragenter',function(e){
        if(!isFileDrag(e))return;
        e.preventDefault();
        dragCounter++;
        overlay.classList.add('active');
      });
      portletMain.addEventListener('dragleave',function(e){
        if(!isFileDrag(e))return;
        dragCounter--;
        if(dragCounter<=0){dragCounter=0;overlay.classList.remove('active');}
      });
      portletMain.addEventListener('dragover',function(e){
        if(!isFileDrag(e))return;
        e.preventDefault();
        e.dataTransfer.dropEffect='copy';
      });
      portletMain.addEventListener('drop',function(e){
        if(!isFileDrag(e))return;
        e.preventDefault();
        dragCounter=0;
        overlay.classList.remove('active');
        var files=e.dataTransfer.files;
        if(!files||files.length===0)return;
        var cur=state.folderStack.length?state.folderStack[state.folderStack.length-1]:null;
        var today=new Date().toISOString().slice(0,10);
        var added=0;
        Array.from(files).forEach(function(file){
          var ext=file.name.split('.').pop().toUpperCase();
          var typeMap={PDF:'PDF',DOCX:'DOCX',DOC:'DOCX',XLSX:'XLSX',XLS:'XLSX'};
          var type=typeMap[ext]||ext;
          var allowed=['PDF','DOCX','XLSX'];
          if(!allowed.includes(type)){showToast('Tipo ".'+ext.toLowerCase()+'" não suportado. Use PDF, DOCX ou XLSX.','error');return;}
          var sizeKB=Math.round(file.size/1024)||1;
          if(sizeKB>20480){showToast('"'+file.name+'" excede o limite de 20 MB.','error');return;}
          var newDoc={id:Date.now()+Math.random(),name:file.name,type:type,date:today,uploadDate:today,owner:'Ana Rocha',size:sizeKB,fileRef:file};
          (cur?cur.docs:state.docs).push(newDoc);
          added++;
        });
        if(added>0){
          render();
          showToast(added===1?'Arquivo enviado com sucesso.':added+' arquivos enviados com sucesso.','success');
        }
      });
    })();

